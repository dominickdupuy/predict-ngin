# Polymarket live trading credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── L1: Polygon wallet private key ───────────────────────────────────────────
# Your Polygon/Ethereum wallet private key (starts with 0x)
# This signs orders locally; it never leaves your machine.
POLYMARKET_PRIVATE_KEY=0x...

# ── L1: Wallet type ──────────────────────────────────────────────────────────
# 0 = EOA (standard MetaMask-style wallet, needs POL for gas)
# 1 = POLY_PROXY (existing Polymarket proxy / Magic Link / Google login)
# 2 = GNOSIS_SAFE (Gnosis Safe multisig)
# 3 = POLY_1271  (deposit wallet — recommended for new API users)
# For a fresh EOA wallet use 0. For an existing Polymarket web account use 1.
POLYMARKET_SIGNATURE_TYPE=0

# ── L1: Funder / deposit wallet address ──────────────────────────────────────
# The Polygon address that holds your USDC trading capital.
# For EOA (type 0): same as your wallet address.
# For POLY_1271 (type 3): your Polymarket deposit wallet address
#   (find it at https://polymarket.com/settings → "Deposit Wallet Address")
POLYMARKET_FUNDER_ADDRESS=0x...

# ── L2: API credentials (generated by scripts/setup_polymarket_keys.py) ─────
# Run `python scripts/setup_polymarket_keys.py` to generate these.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Network ───────────────────────────────────────────────────────────────────
# 137 = Polygon mainnet (real money)
# 80002 = Amoy testnet (no-cost testing)
POLYMARKET_CHAIN_ID=137

# ── Optional: News API key for latency-arb strategy ──────────────────────────
# Get a free key at https://newsapi.org or https://eventregistry.org
NEWSAPI_KEY=
